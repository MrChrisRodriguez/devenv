# Dev container secrets — copy to ~/.config/devcontainer/secrets and chmod 600
#
# Two-tier system:
#   Common  → ~/.config/devcontainer/secrets               (shared across all projects)
#   Project → ~/.config/devcontainer/secrets.d/<project>   (per-project overrides)
#
# The value in secrets.d/<project> wins when the same key appears in both files.
# Both files use the same KEY=value format (no export, no quotes needed).

# ── AI Tools ─────────────────────────────────────────────────────────────────

# Context7 MCP server (https://context7.com)
CONTEXT7_API_KEY=

# Anthropic API key (for Claude API usage outside Claude Code)
# ANTHROPIC_API_KEY=

# OpenAI API key (for Opencode Codex auth plugin)
# OPENAI_API_KEY=

# ── Project-specific (put these in secrets.d/<project>) ──────────────────────

# Database
# DATABASE_URL=

# Auth / OAuth
# AUTH_SECRET=

# Third-party services
# STRIPE_SECRET_KEY=
# RESEND_API_KEY=
