{
	"name": "Development",
	"build": {
		"dockerfile": "Dockerfile"
	},
	"features": {
		"ghcr.io/devcontainers/features/docker-in-docker:2": {},
		"ghcr.io/devcontainers/features/git:1": {},
		"ghcr.io/devcontainers/features/github-cli:1": {},
		"ghcr.io/devcontainers/features/node:1": {
			"version": "lts",
			"nodeGypDependencies": false
		},
		"ghcr.io/devcontainers/features/common-utils:2": {
			"installZsh": true,
			"configureZshAsDefaultShell": false,
			"installOhMyZsh": false,
			"username": "vscode",
			"userUid": "automatic",
			"userGid": "automatic"
		}
	},
	"onCreateCommand": ["bash", "/workspace/.devcontainer/on-create.sh"],
	"postCreateCommand": [
		"bash",
		"-c",
		"export PATH=\"$HOME/.proto/shims:$HOME/.proto/bin:$PATH\""
	],
	"customizations": {
		"vscode": {
			"extensions": [
				"anthropic.claude-code",
				"biomejs.biome",
				"bradlc.vscode-tailwindcss",
				"cloudflare.vscode-cloudflare-workers",
				"foam.foam-vscode",
				"infisical.infisical-vscode",
				"karunamurti.tera",
				"ms-vscode.vscode-docker",
				"ms-vscode.vscode-json",
				"ms-vscode.vscode-typescript-next",
				"redhat.vscode-yaml",
				"shd101wyy.markdown-preview-enhanced"
			],
			"settings": {
				"terminal.integrated.defaultProfile.linux": "zsh",
				"terminal.integrated.profiles.linux": {
					"zsh": {
						"path": "/usr/bin/zsh",
						"args": ["-l"]
					},
					"bash": {
						"path": "/usr/bin/bash",
						"args": ["-l"]
					}
				},
				"typescript.preferences.preferTypeOnlyAutoImports": true,
				"editor.formatOnSave": true,
				"editor.defaultFormatter": "biomejs.biome",
				"editor.codeActionsOnSave": {
					"source.fixAll": "explicit"
				},
				"foam.files.newNotePath": "root",
				"foam.files.notesExtensions": "mdc",
				"[typescript]": {
					"editor.defaultFormatter": "biomejs.biome"
				},
				"[yaml]": {
					"editor.defaultFormatter": "redhat.vscode-yaml"
				},
				"[yml]": {
					"editor.defaultFormatter": "redhat.vscode-yaml"
				}
			}
		}
	},
	"postStartCommand": [
		"bash",
		"-c",
		"export PATH=\"$HOME/.proto/shims:$HOME/.proto/bin:$PATH\" && bun install"
	],
	"waitFor": "postStartCommand",
	"forwardPorts": [3000, 4000, 8080, 8787],
	"portsAttributes": {
		"3000": {
			"label": "Next.js Dev Server",
			"onAutoForward": "notify"
		},
		"4000": {
			"label": "NestJS/ElysiaJS Server",
			"onAutoForward": "notify"
		},
		"8080": {
			"label": "Development Server",
			"onAutoForward": "silent"
		},
		"8787": {
			"label": "Cloudflare Workers Dev",
			"onAutoForward": "notify"
		}
	},
	"remoteUser": "vscode",
	"workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
	"workspaceFolder": "/workspace",
	"mounts": [
		"source=claude-code-shellhistory-${devcontainerId},target=/commandhistory,type=volume",
		"source=claude-code-config-${devcontainerId},target=/home/vscode/.claude,type=volume",
		"source=proto-home-${devcontainerId},target=/home/vscode/.proto,type=volume",
		"source=${localEnv:HOME}/.local/share/opencode,target=/mnt/opencode-mount,type=bind,consistency=cached",
		"source=${localEnv:HOME}/.ssh,target=/mnt/host-ssh,type=bind,readonly,consistency=cached",
		"source=${localEnv:HOME}/.config/devcontainer,target=/run/devcontainer-config,type=bind,readonly,consistency=cached"
	],
	"containerEnv": {
		"DEVCONTAINER": "true",
		"DEVCONTAINER_PROJECT": "my-project",
		"SHELL": "/usr/bin/zsh",
		"TERM": "xterm-256color",
		"COLORTERM": "truecolor",
		"POWERLEVEL9K_DISABLE_GITSTATUS": "true"
	},
	"remoteEnv": {
		"NODE_OPTIONS": "--max-old-space-size=4096",
		"CLAUDE_CONFIG_DIR": "/home/vscode/.claude",
		"GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
	},
	"_comment_secrets": "Two-tier secrets — both files use KEY=value format (one per line, # for comments). (1) Common: ~/.config/devcontainer/secrets — loaded in every project; good for shared keys like GITHUB_TOKEN (raises proto/GitHub API rate limit from 60 to 5000 req/hr) and CONTEXT7_API_KEY. (2) Per-project: ~/.config/devcontainer/secrets.d/<DEVCONTAINER_PROJECT> — loaded only for this container; good for project-specific tokens. Per-project values override common ones when the same key appears in both. Update DEVCONTAINER_PROJECT to a short lowercase slug matching your project when creating a new project from this template. GITHUB_TOKEN is also auto-passed from the host shell via remoteEnv if already set there."
}
