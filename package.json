{
	"name": "devenv-template",
	"workspaces": {
		"packages": [
			"apps/*",
			"libs/*",
			"scripts/*"
		],
		"catalog": {
			"@biomejs/biome": "^2",
			"@fission-ai/openspec": "latest",
			"@types/bun": "latest",
			"@types/node": "latest",
			"dotenv": "latest",
			"husky": "latest",
			"opencode-ai": "latest",
			"tsx": "latest",
			"typescript": "latest"
		}
	},
	"engines": {
		"node": "~22"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@commitlint/cli": "latest",
		"@commitlint/config-conventional": "latest",
		"@fission-ai/openspec": "^0.19.0",
		"@types/bun": "latest",
		"husky": "catalog:",
		"lint-staged": "latest",
		"opencode-ai": "catalog:"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"scripts": {
		"prepare": "husky"
	},
	"lint-staged": {
		"*": [
			"biome check --write --no-errors-on-unmatched"
		]
	},
	"commitlint": {
		"extends": [
			"@commitlint/config-conventional"
		],
		"rules": {
			"type-enum": [
				2,
				"always",
				[
					"feat",
					"fix",
					"refactor",
					"chore",
					"docs",
					"test"
				]
			],
			"subject-case": [
				2,
				"never",
				[
					"start-case",
					"pascal-case",
					"upper-case"
				]
			],
			"subject-empty": [
				2,
				"never"
			],
			"subject-full-stop": [
				2,
				"never",
				"."
			],
			"header-max-length": [
				2,
				"always",
				72
			]
		}
	}
}
