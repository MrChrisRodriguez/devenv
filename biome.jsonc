{
	"$schema": "https://biomejs.dev/schemas/2.3.11/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"linter": {
		"rules": {
			"complexity": {
				"noForEach": "off"
			}
		}
	},
	"files": {
		"includes": ["**", "!**/worker-configuration.d.ts", "!**/*.tera"]
	}
}
