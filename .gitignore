# Logs
**/*.log
**/logs/

# Environment files
**/.env*
!**/.env.example
**/.dev.vars

# Cache directories
**/.cache/
**/.eslintcache
**/.moon/cache/
**/.moon/docker/
**/.nx/cache/
**/.nx/installation/
**/.nx/workspace-data/
**/.pnp*
**/.yarn/

# Build outputs
**/dist/
**/out/
**/.output/
**/build/
**/coverage/
**/tmp/
**/.temp/
**/.nitro/

# Convex
**/convex/.cache
**/convex/_generated

# IDE files
**/.DS_Store
**/.idea/

# Package managers
**/node_modules/
**/.pnp*

# Cloudflare
**/.wrangler/

# Next.js
**/.next/

# Credentials
.coda-credentials.json
**/opencode/auth.json

# One-time relay file for seeding ~/.config into the config-home volume
# (see CHANGES.md 2026-05-28). Transient — delete after the post-rebuild restore.
.ccstatusline-settings.bak

# DMNO files
**/.dmno/.env.local
**/.dmno/.icon-cache
**/.dmno/.typegen/
**/.dmno/cache-key.json
**/.dmno/cache.json
**/.dmno/certs/

# Test coverage
**/*.lcov
**/report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Archives
**/*.tgz

# TypeScript
**/*.tsbuildinfo

# Graphify (per https://github.com/safishamsi/graphify README)
# Keep graph.json, graph.html, GRAPH_REPORT.md, cache/ committed — they're
# the shared knowledge graph. Ignore only the per-user noise files.
graphify-out/manifest.json
graphify-out/cost.json
# Per-container pointers (absolute paths to the repo root + uv-tools python) and
# the rebuild lock — regenerated in each container, so they must not be tracked.
graphify-out/.graphify_root
graphify-out/.graphify_python
graphify-out/.rebuild.lock

